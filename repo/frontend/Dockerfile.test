FROM node:20-alpine
WORKDIR /app
COPY package.json package-lock.json angular.json tsconfig.json tsconfig.app.json tsconfig.spec.json vitest.config.ts proxy.conf.json ngsw-config.json ./
RUN npm config set fetch-retries 5 \
 && npm config set fetch-retry-mintimeout 20000 \
 && npm config set fetch-retry-maxtimeout 120000 \
 && (npm ci --no-audit --no-fund --loglevel=error \
     || npm ci --no-audit --no-fund --loglevel=error \
     || npm install --no-audit --no-fund --loglevel=error)
COPY src ./src
COPY public ./public
CMD ["sh", "-c", "npm test -- --watch=false && npm run build"]
